# Websocket endpoint the browser connects to.
VITE_WS_URL=ws://localhost:8080

# Base path for API calls, proxied by the dev server.
VITE_API_URL=/api/v1

# Dev-server proxy targets. Defaults in vite.config.ts point at the k8s
# service names; these override them for running locally without k8s.
API_PROXY_TARGET=http://localhost:3000
WS_PROXY_TARGET=ws://localhost:8080
